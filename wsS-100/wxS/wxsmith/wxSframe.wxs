<?xml version="1.0" encoding="utf-8" ?>
<wxsmith>
	<object class="wxFrame" name="wxSFrame">
		<size>778,450</size>
		<object class="wxPanel" name="ID_PANEL1" variable="Panel1" member="yes">
			<pos>400,216</pos>
			<size>608,328</size>
			<focused>1</focused>
			<handler function="OnMouseKlik" entry="EVT_LEFT_UP" />
			<handler function="OnMouseKlik" entry="EVT_RIGHT_UP" />
			<handler function="OnMouseUse" entry="EVT_MOTION" />
		</object>
		<object class="wxMenuBar" variable="MenuBar1" member="no">
			<object class="wxMenu" variable="mInfo" member="no">
				<label>&amp;Informacje</label>
				<object class="wxMenuItem" name="ID_SHOW_DATE" variable="miData" member="yes">
					<label>Pokaz date</label>
					<handler function="OnShowDate" entry="EVT_MENU" />
					<checkable>1</checkable>
				</object>
				<object class="wxMenuItem" name="ID_SHOW_VERSION" variable="MenuItem1" member="yes">
					<label>Pokaz wersje systemu</label>
					<handler function="OnShowVersion" entry="EVT_MENU" />
				</object>
			</object>
		</object>
		<object class="wxStatusBar" name="ID_STATUSBAR1" variable="StatusBar1" member="yes">
			<fields>3</fields>
			<widths>-1,-10,-10</widths>
			<styles>wxSB_RAISED,wxSB_RAISED,wxSB_RAISED</styles>
		</object>
	</object>
</wxsmith>
